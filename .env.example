# ============================================================================
# LUMIR AIR v14 - Environment Configuration Example
# ============================================================================
# Copy this file to .env and fill in your values
# Or set these as environment variables directly
# NOTE: Do NOT commit .env to git - it contains secrets!

# ============================================================================
# DIRECTORIES
# ============================================================================

# Root data directory (default: ~/.lumir_air on desktop, ~/lumir_air_v14 on Android)
# LUMIR_ROOT=/home/user/.lumir_air

# Reports output directory (default: platform-specific)
# LUMIR_REPORTS=/storage/emulated/0/Download/LUMIR

# Cache directory (default: $LUMIR_ROOT/cache)
# LUMIR_CACHE=/home/user/.lumir_air/cache

# Logs directory (default: $LUMIR_ROOT/logs)
# LUMIR_LOGS=/home/user/.lumir_air/logs

# Data directory (default: $LUMIR_ROOT/data)
# LUMIR_DATA=/home/user/.lumir_air/data

# ============================================================================
# NETWORK CONFIGURATION
# ============================================================================

# Default timeout for all network requests (seconds)
# LUMIR_TIMEOUT=20

# Maximum number of retry attempts for failed requests
# LUMIR_MAX_RETRIES=3

# Retry backoff multiplier (exponential: delay * backoff^attempt)
# LUMIR_RETRY_BACKOFF=0.5

# Custom User-Agent header
# LUMIR_USER_AGENT="LUMIR AIR 14"

# ============================================================================
# API KEYS - REQUIRED FOR FEATURES
# ============================================================================

# GitHub API Token (https://github.com/settings/tokens)
# Increases rate limit from 60 to 5000 requests per hour
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# YouTube API Key (https://console.cloud.google.com/)
# Required for music search functionality
# YOUTUBE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# OLLAMA / LOCAL LLM CONFIGURATION
# ============================================================================

# Ollama server URL (default: http://127.0.0.1:11434)
# OLLAMA_URL=http://127.0.0.1:11434

# Ollama model name (default: lumir:latest)
# OLLAMA_MODEL=lumir:latest

# Ollama request timeout (seconds, default: 30)
# OLLAMA_TIMEOUT=30

# Maximum retry attempts for Ollama requests (default: 2)
# OLLAMA_MAX_RETRIES=2

# Initial retry delay (seconds, default: 1.0)
# Uses exponential backoff: delay * (2 ^ attempt)
# OLLAMA_RETRY_DELAY=1.0

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable LLM features (requires Ollama running)
# LUMIR_ENABLE_LLM=true

# Enable caching of API responses
# LUMIR_ENABLE_CACHE=true

# Cache time-to-live (seconds, default: 3600 = 1 hour)
# LUMIR_CACHE_TTL=3600
